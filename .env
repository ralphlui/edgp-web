# API Endpoints
VITE_ADMIN_API_URL=https://DOMAIN-URL/api/admin
VITE_ORGANIZATION_API_URL=https://DOMAIN-URL/api
VITE_POLICY_API_URL=https://DOMAIN-URL/api
VITE_RULES_API_URL=https://DOMAIN-URL/api
VITE_MDM_API_URL=https://DOMAIN-URL/api/mdm
VITE_WORKFLOW_API_URL=https://DOMAIN-URL/api

#local development configuration
# Uncomment the lines below to use local development configuration
# VITE_ADMIN_API_URL=http://localhost:8081/api/admin
# VITE_ORGANIZATION_API_URL=http://localhost:8082/api
# VITE_POLICY_API_URL=http://localhost:8089/api
# VITE_RULES_API_URL=http://localhost:8090/api
# VITE_MDM_API_URL=http://localhost:8083/api/mdm
# VITE_WORKFLOW_API_URL=http://localhost:8084/api

# API Configuration
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_AUTH=true
VITE_ENABLE_USER_MANAGEMENT=true

# Other Configuration
VITE_APP_NAME="EDGP Admin"
VITE_APP_VERSION="1.0.0"
